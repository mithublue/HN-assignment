# =============================================================================
# Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your actual values
# Command: cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration (MySQL)
# -----------------------------------------------------------------------------
# Full connection string format: mysql://user:password@host:port/database
DATABASE_URL="mysql://root:@localhost:3306/hackernews"

# Individual connection parameters (used by Prisma 7 adapter)
DATABASE_USER="root"
DATABASE_PASSWORD=""
DATABASE_NAME="hackernews"
DATABASE_HOST="localhost"
DATABASE_PORT=3306

# -----------------------------------------------------------------------------
# AI Configuration (Mistral AI)
# -----------------------------------------------------------------------------
# Get your API key from: https://console.mistral.ai/
MISTRAL_API_KEY="your_mistral_api_key_here"

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
# Environment: development, production, test
NODE_ENV="development"

# -----------------------------------------------------------------------------
# Docker-specific Configuration
# -----------------------------------------------------------------------------
# When running with Docker Compose, these values are overridden
# See docker-compose.yml for Docker environment variables
