// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Bookmark {
  id          String   @id @default(cuid())
  storyId     Int      @unique
  title       String
  url         String?
  author      String
  points      Int
  commentCount Int
  createdAt   DateTime @default(now())
  
  @@index([storyId])
}

model Summary {
  id          String   @id @default(cuid())
  storyId     Int      @unique
  keyPoints   Json     // Array of strings stored as JSON
  sentiment   String
  summary     String   @db.Text
  createdAt   DateTime @default(now())
  
  @@index([storyId])
}
